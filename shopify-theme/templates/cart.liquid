<div style="max-width:900px;margin:40px auto;padding:0 24px"><h1 style="font-family:Georgia,serif;font-weight:400">Your Bag</h1>{% form 'cart', cart %}{% for item in cart.items %}<div style="display:flex;gap:16px;padding:14px 0;border-bottom:1px solid #eee"><img src="{{ item.image | image_url: width: 120 }}" width="80" alt=""><div><div>{{ item.product.title }}</div><div>{{ item.final_price | money }} &times; {{ item.quantity }}</div></div></div>{% else %}<p>Your bag is empty.</p>{% endfor %}{% if cart.item_count > 0 %}<button class="addbtn" name="checkout" style="max-width:280px">Checkout &middot; {{ cart.total_price | money }}</button>{% endif %}{% endform %}</div>
