<div style="max-width:820px;margin:40px auto 70px;padding:0 24px">
  <h1 style="font-family:Georgia,serif;font-weight:400;font-size:24px;margin:0 0 18px">Your Bag</h1>
  {% form 'cart', cart %}
    {% for item in cart.items %}
      <div style="display:flex;gap:16px;padding:16px 0;border-bottom:1px solid #eee;align-items:center">
        <a href="{{ item.url }}"><img src="{{ item.image | image_url: width: 160 }}" width="80" height="107" alt="{{ item.product.title | escape }}" style="object-fit:cover;background:#f5f5f5"></a>
        <div style="flex:1">
          <a href="{{ item.url }}" style="display:block;font-size:13px;margin-bottom:4px">{{ item.product.title }}</a>
          {% unless item.product.has_only_default_variant %}<div style="color:#888;font-size:12px;margin-bottom:4px">{{ item.variant.title }}</div>{% endunless %}
          <div style="color:#555;font-size:12px">Qty {{ item.quantity }}</div>
        </div>
        <div style="font-size:13px">{{ item.final_line_price | money }}</div>
      </div>
    {% else %}
      <p style="color:#888;padding:30px 0">Your bag is empty. <a href="{{ routes.all_products_collection_url }}" style="text-decoration:underline">Start shopping</a>.</p>
    {% endfor %}
    {% if cart.item_count > 0 %}
      <div style="display:flex;justify-content:space-between;align-items:center;margin:22px 0 8px;font-size:14px">
        <span style="color:#888">Subtotal</span>
        <strong>{{ cart.total_price | money }}</strong>
      </div>
      <p style="color:#999;font-size:11px;margin:0 0 16px">Shipping &amp; taxes calculated at checkout.</p>
      <button class="addbtn" name="checkout" style="max-width:320px">Checkout &middot; {{ cart.total_price | money }}</button>
    {% endif %}
  {% endform %}
</div>
