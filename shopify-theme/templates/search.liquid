<div style="max-width:1100px;margin:30px auto;padding:0 18px"><form action="{{ routes.search_url }}" method="get"><input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search" style="width:100%;padding:12px;border:1px solid #ccc"></form><div class="product-grid">{% for item in search.results %}{% if item.object_type == 'product' %}<a class="pcard" href="{{ item.url }}"><div class="imgwrap"><img src="{{ item.featured_image | image_url: width: 600 }}" alt="" loading="lazy"></div><div class="t">{{ item.title }}</div><div class="p">{{ item.price | money }}</div></a>{% endif %}{% endfor %}</div></div>
