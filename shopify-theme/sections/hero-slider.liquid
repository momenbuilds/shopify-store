<div class="hero" data-hero>
  <div class="hero-track">
    {%- for block in section.blocks -%}
      <div class="hero-slide" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
        <img src="{{ block.settings.image_url }}" alt="{{ block.settings.alt | escape }}" width="1600" height="2000" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
        {%- if block.settings.link != blank -%}</a>{%- endif -%}
      </div>
    {%- endfor -%}
  </div>
  {%- if section.blocks.size > 1 -%}
    <button class="hero-arrow prev" data-hero-prev aria-label="Previous">&#8249;</button>
    <button class="hero-arrow next" data-hero-next aria-label="Next">&#8250;</button>
  {%- endif -%}
</div>

<script>
(function(){
  var root=document.querySelector('[data-hero]'); if(!root) return;
  var track=root.querySelector('.hero-track'), slides=root.querySelectorAll('.hero-slide'), i=0;
  function go(n){ i=(n+slides.length)%slides.length; track.style.transform='translateX('+(-i*100)+'%)'; }
  var p=root.querySelector('[data-hero-prev]'), nx=root.querySelector('[data-hero-next]');
  if(p) p.addEventListener('click',function(){go(i-1)});
  if(nx) nx.addEventListener('click',function(){go(i+1)});
  if(slides.length>1) setInterval(function(){go(i+1)},6000);
})();
</script>

{% schema %}
{
  "name": "Hero slider",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "text", "id": "image_url", "label": "Image URL" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slider",
      "blocks": [
        { "type": "slide", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/80166_OPA_002_26-Edit.jpg" } },
        { "type": "slide", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/MW935HP-Z166SZ28400MN.jpg" } },
        { "type": "slide", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/ML082-Z316S1620000.jpg" } }
      ]
    }
  ]
}
{% endschema %}
