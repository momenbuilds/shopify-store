<div class="hero" data-hero>
  <div class="hero-track">
    {%- for block in section.blocks -%}
      {%- assign slide_handle = block.settings.product_handle -%}
      {%- if slide_handle == blank and block.settings.link contains '/products/' -%}
        {%- assign slide_handle = block.settings.link | split: '/products/' | last | split: '?' | first -%}
      {%- endif -%}
      {%- assign slide_product = all_products[slide_handle] -%}
      {%- if slide_product != blank -%}
        {%- assign slide_href = slide_product.url -%}
        {%- assign slide_label = block.settings.cta_label | default: slide_product.title -%}
        {%- assign slide_alt = block.settings.alt | default: slide_product.title -%}
      {%- elsif block.settings.link != blank -%}
        {%- assign slide_href = block.settings.link -%}
        {%- assign slide_label = block.settings.cta_label | default: 'Shop Now' -%}
        {%- assign slide_alt = block.settings.alt -%}
      {%- else -%}
        {%- assign slide_href = '' -%}
        {%- assign slide_label = '' -%}
        {%- assign slide_alt = block.settings.alt -%}
      {%- endif -%}
      {%- comment -%} Image: a manual URL or theme-asset filename wins, otherwise pull the linked product's image. {%- endcomment -%}
      {%- if block.settings.image_url != blank -%}
        {%- if block.settings.image_url contains '//' -%}
          {%- assign slide_img_src = block.settings.image_url -%}
        {%- else -%}
          {%- assign slide_img_src = block.settings.image_url | asset_url -%}
        {%- endif -%}
      {%- elsif slide_product != blank and slide_product.featured_image -%}
        {%- assign slide_img_src = slide_product.featured_image | image_url: width: 1600 -%}
      {%- else -%}
        {%- assign slide_img_src = '' -%}
      {%- endif -%}
      <div class="hero-slide" {{ block.shopify_attributes }}>
        {%- if slide_href != blank -%}
          <a class="hero-slide-link" href="{{ slide_href }}" aria-label="{{ slide_label | escape }}">
            <img src="{{ slide_img_src }}" alt="{{ slide_alt | escape }}" width="1600" height="2000"
                 loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
            <div class="hero-cta-wrap">
              {%- if block.settings.heading != blank -%}
                <p class="hero-heading">{{ block.settings.heading }}</p>
              {%- endif -%}
              <span class="hero-cta-btn">{{ slide_label }}</span>
            </div>
          </a>
        {%- else -%}
          <img src="{{ slide_img_src }}" alt="{{ slide_alt | escape }}" width="1600" height="2000"
               loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
  {%- if section.blocks.size > 1 -%}
    <button class="hero-arrow prev" data-hero-prev aria-label="Previous">&#8249;</button>
    <button class="hero-arrow next" data-hero-next aria-label="Next">&#8250;</button>
  {%- endif -%}
</div>

<script>
(function(){
  var root=document.querySelector('[data-hero]'); if(!root) return;
  var track=root.querySelector('.hero-track'), slides=root.querySelectorAll('.hero-slide'), i=0;
  function go(n){ i=(n+slides.length)%slides.length; track.style.transform='translateX('+(-i*100)+'%)'; }
  var p=root.querySelector('[data-hero-prev]'), nx=root.querySelector('[data-hero-next]');
  if(p) p.addEventListener('click',function(e){e.preventDefault();go(i-1);});
  if(nx) nx.addEventListener('click',function(e){e.preventDefault();go(i+1);});
  if(slides.length>1) setInterval(function(){go(i+1)},6000);
})();
</script>

{% schema %}
{
  "name": "Hero slider",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "text", "id": "image_url", "label": "Image URL", "info": "Full image URL, or a theme asset filename like hero-1.jpg. Leave blank to use the linked product's image." },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "text", "id": "heading", "label": "Heading (optional overlay text)" },
        { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop Now" },
        { "type": "text", "id": "product_handle", "label": "Product handle", "info": "Links to a product. Takes priority over the link below." },
        { "type": "url", "id": "link", "label": "Link (fallback)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slider",
      "blocks": [
        { "type": "slide", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/80166_OPA_002_26-Edit.jpg", "cta_label": "Shop Now" } },
        { "type": "slide", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/MW935HP-Z166SZ28400MN.jpg", "cta_label": "Shop Now" } },
        { "type": "slide", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/ML082-Z316S1620000.jpg", "cta_label": "Shop Now" } }
      ]
    }
  ]
}
{% endschema %}
