{%- if section.settings.title != blank -%}
  <h2 class="stl-title">{{ section.settings.title }}</h2>
{%- endif -%}
<div class="stl-grid">
  {%- for block in section.blocks -%}
    {%- assign tile_product = all_products[block.settings.product_handle] -%}
    {%- if tile_product != blank -%}
      {%- assign tile_href = tile_product.url -%}
      {%- assign tile_alt = block.settings.alt | default: tile_product.title -%}
    {%- elsif block.settings.link != blank -%}
      {%- assign tile_href = block.settings.link -%}
      {%- assign tile_alt = block.settings.alt -%}
    {%- else -%}
      {%- assign tile_href = routes.all_products_collection_url -%}
      {%- assign tile_alt = block.settings.alt -%}
    {%- endif -%}
    <a href="{{ tile_href }}" {{ block.shopify_attributes }}>
      <img src="{{ block.settings.image_url }}" alt="{{ tile_alt | escape }}" loading="lazy">
    </a>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Shop the look",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "SHOP THE LOOK" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "text", "id": "image_url", "label": "Image URL" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "text", "id": "product_handle", "label": "Product handle", "info": "Links to a product in your store. Takes priority over the manual link below." },
        { "type": "url", "id": "link", "label": "Link (fallback)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the look",
      "blocks": [
        { "type": "tile", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/MW922-1338S07100UK_02_7d45b958-be8c-43f6-9510-dc136bb7f203.jpg" } },
        { "type": "tile", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/MH228E-58PS5740000-1.jpg" } },
        { "type": "tile", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/MU781GB6CZ399888-01.jpg" } },
        { "type": "tile", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/MU650B65VT14888-01_88e988b7-1ad7-4bca-baab-3a5862cc27d9.jpg" } },
        { "type": "tile", "settings": { "image_url": "https://cdn.shopify.com/s/files/1/0455/9827/7796/files/MU65027SSK888-01.jpg" } },
