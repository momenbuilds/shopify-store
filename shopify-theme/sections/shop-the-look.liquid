{%- if section.settings.title != blank -%}
  <h2 class="stl-title">{{ section.settings.title }}</h2>
{%- endif -%}
<div class="stl-grid">
  {%- for block in section.blocks -%}
    {%- assign look_id = 'look-' | append: block.id -%}
    {%- comment -%} Look photo: manual URL wins, otherwise the first product's image. {%- endcomment -%}
    {%- assign first_handle = block.settings.products | split: ',' | first | strip -%}
    {%- assign first_prod = all_products[first_handle] -%}
    {%- if block.settings.image_url != blank -%}
      {%- assign look_img_src = block.settings.image_url -%}
    {%- elsif first_prod != blank and first_prod.featured_image -%}
      {%- assign look_img_src = first_prod.featured_image | image_url: width: 700 -%}
    {%- else -%}
      {%- assign look_img_src = '' -%}
    {%- endif -%}
    <button type="button" class="stl-look" data-look-open="{{ look_id }}" {{ block.shopify_attributes }} aria-label="Shop this look">
      <img src="{{ look_img_src }}" alt="{{ block.settings.alt | escape }}" width="700" height="700" loading="lazy">
      <span class="stl-cta">{{ section.settings.cta | default: 'SHOP THIS LOOK' }}</span>
    </button>
  {%- endfor -%}
</div>

{%- comment -%} ---- modals ---- {%- endcomment -%}
{%- for block in section.blocks -%}
  {%- assign look_id = 'look-' | append: block.id -%}
  {%- assign first_handle = block.settings.products | split: ',' | first | strip -%}
  {%- assign first_prod = all_products[first_handle] -%}
  {%- if block.settings.image_url != blank -%}
    {%- assign look_thumb_src = block.settings.image_url -%}
  {%- elsif first_prod != blank and first_prod.featured_image -%}
    {%- assign look_thumb_src = first_prod.featured_image | image_url: width: 120 -%}
  {%- else -%}
    {%- assign look_thumb_src = '' -%}
  {%- endif -%}
  <div class="look-modal" id="{{ look_id }}" data-look-modal hidden>
    <div class="look-overlay" data-look-close></div>
    <div class="look-dialog" role="dialog" aria-modal="true" aria-label="Shop this look">
      <div class="look-modal-head">
        <img class="look-hero-thumb" src="{{ look_thumb_src }}" alt="{{ block.settings.alt | escape }}" width="56" height="56" loading="lazy">
        <span class="look-modal-label">SHOP THIS LOOK</span>
        <button type="button" class="look-x" data-look-close aria-label="Close">{% render 'icon', name: 'close', size: 18 %}</button>
      </div>
      <div class="look-products">
        {%- assign handles = block.settings.products | split: ',' -%}
        {%- for h in handles -%}
          {%- assign hh = h | strip -%}
          {%- assign prod = all_products[hh] -%}
          {%- if prod != empty and prod.id -%}
            <a class="look-card" href="{{ prod.url }}">
              <span class="look-thumb">
                <img src="{{ prod.featured_image | image_url: width: 300 }}" alt="{{ prod.title | escape }}" width="300" height="400" loading="lazy">
                <span class="look-add">{% render 'icon', name: 'plus', size: 14 %}</span>
              </span>
              <span class="look-name">{{ prod.title }}</span>
              <span class="look-price">{{ prod.price | money }}</span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endfor -%}

<script>
(function(){
  function close(){document.querySelectorAll('[data-look-modal]').forEach(function(m){m.setAttribute('hidden','')});document.body.classList.remove('menu-open');}
  document.querySelectorAll('[data-look-open]').forEach(function(b){
    b.addEventListener('click',function(){
      var m=document.getElementById(b.getAttribute('data-look-open'));
      if(m){m.removeAttribute('hidden');document.body.classList.add('menu-open');}
    });
  });
  document.querySelectorAll('[data-look-close]').forEach(function(x){x.addEventListener('click',close);});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')close();});
})();
</script>

{% schema %}
{
  "name": "Shop the look",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "SHOP THIS LOOK" },
    { "type": "text", "id": "cta", "label": "Overlay label", "default": "SHOP THIS LOOK" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Look",
      "settings": [
        { "type": "text", "id": "image_url", "label": "Image URL" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "textarea", "id": "products", "label": "Product handles (comma separated, up to 4)" }
      ]
    }
  ]
}
{% endschema %}
