{%- comment -%} ---- personalization: derive category + short copy from each product ---- {%- endcomment -%}
{%- assign t = product.title | downcase -%}
{%- assign cat_label = 'StreetWear Dreams' -%}
{%- assign cat_line = 'an everyday essential designed to slot effortlessly into your rotation' -%}
{%- assign cat_fit = 'Relaxed, true-to-size fit.' -%}
{%- assign cat_features = 'Soft, breathable everyday fabric|Versatile cut that layers with anything|Holds its shape wash after wash' | split: '|' -%}
{%- assign cat_material = 'Premium mid-weight blend chosen for comfort and durability.' -%}
{%- if t contains 'jean' or t contains 'denim' -%}
  {%- assign cat_label = 'Denim' -%}
  {%- assign cat_line = 'cut for that perfect Y2K silhouette &mdash; a low-rise lean and a leg that moves with you' -%}
  {%- assign cat_fit = 'True-to-size, low-rise sit with a little stretch. Size down for snug.' -%}
  {%- assign cat_features = 'Low-rise, body-skimming fit|Just-right stretch that moves with you|Classic five-pocket styling' | split: '|' -%}
  {%- assign cat_material = 'Comfort-stretch denim with a vintage-inspired wash.' -%}
{%- elsif t contains 'jort' -%}
  {%- assign cat_label = 'Denim' -%}
  {%- assign cat_line = 'the denim-short hybrid you reach for all summer &mdash; relaxed through the leg with a broken-in feel' -%}
  {%- assign cat_fit = 'Relaxed, mid-length fit. True to size; size up for oversized.' -%}
  {%- assign cat_features = 'Relaxed mid-length leg|Broken-in, vintage denim feel|Raw-edge hem detailing' | split: '|' -%}
  {%- assign cat_material = 'Heavyweight non-stretch denim built to last.' -%}
{%- elsif t contains 'short' -%}
  {%- assign cat_label = 'Shorts' -%}
  {%- assign cat_line = 'a low-rise, lace-trim moment made for warm days and going-out nights' -%}
  {%- assign cat_fit = 'Low-rise, cheeky cut. True to size; size up for more coverage.' -%}
  {%- assign cat_features = 'Low-rise, cheeky cut|Delicate lace-trim detailing|Lightweight and breathable' | split: '|' -%}
  {%- assign cat_material = 'Soft brushed fabric finished with lace trim.' -%}
{%- elsif t contains 'pant' or t contains 'trouser' or t contains 'legging' -%}
  {%- assign cat_label = 'Bottoms' -%}
  {%- assign cat_line = 'an easy drape that dresses up or down without a second thought' -%}
  {%- assign cat_fit = 'Relaxed through the hip and leg. True to size for a flowy fit.' -%}
  {%- assign cat_features = 'Easy wide-leg drape|High, comfortable waist|Flowy, breathable feel' | split: '|' -%}
  {%- assign cat_material = 'Lightweight woven fabric with beautiful movement.' -%}
{%- elsif t contains 'tank' or t contains 'cami' or t contains 'vest' -%}
  {%- assign cat_label = 'Tops' -%}
  {%- assign cat_line = 'a fitted, second-skin layer that works solo or under everything' -%}
  {%- assign cat_fit = 'Slim, cropped fit. Stretches to hug; size up for looser.' -%}
  {%- assign cat_features = 'Fitted, second-skin silhouette|Smooth stretch ribbing|Layer solo or under anything' | split: '|' -%}
  {%- assign cat_material = 'Stretch rib-knit with a soft hand-feel.' -%}
{%- elsif t contains 'top' or t contains 'tee' or t contains 'shirt' or t contains 'crop' or t contains 'milkmaid' -%}
  {%- assign cat_label = 'Tops' -%}
  {%- assign cat_line = 'a slim, cropped staple with the kind of detail that makes the whole fit' -%}
  {%- assign cat_fit = 'Cropped, true-to-size fit. Size up for extra length.' -%}
  {%- assign cat_features = 'Cropped, flattering length|Soft, breathable cotton-feel|Statement detailing' | split: '|' -%}
  {%- assign cat_material = 'Soft cotton-blend jersey.' -%}
{%- elsif t contains 'necklace' or t contains 'pendant' or t contains 'charm' -%}
  {%- assign cat_label = 'Jewelry' -%}
  {%- assign cat_line = 'a delicate gold-tone piece that finishes any neckline' -%}
  {%- assign cat_fit = 'One size. Adjustable, tarnish-resistant chain.' -%}
  {%- assign cat_features = '18K gold-plated finish|Tarnish-resistant stainless steel|Adjustable, comfortable chain' | split: '|' -%}
  {%- assign cat_material = '18K gold-plated stainless steel. Hypoallergenic and water-resistant.' -%}
{%- elsif t contains 'clip' or t contains 'claw' -%}
  {%- assign cat_label = 'Accessories' -%}
  {%- assign cat_line = 'the grip-it-and-go claw that holds thick hair all day' -%}
  {%- assign cat_fit = 'One size. Strong-hold grip for thick and fine hair.' -%}
  {%- assign cat_features = 'Strong, all-day hold|Suits thick and fine hair|Lightweight, comfortable grip' | split: '|' -%}
  {%- assign cat_material = 'Durable acetate-style resin.' -%}
{%- endif -%}
{%- assign size_opt = blank -%}
{%- for option in product.options_with_values -%}
  {%- assign on = option.name | downcase -%}
  {%- if on contains 'size' -%}{%- assign size_opt = option -%}{%- endif -%}
{%- endfor -%}

<div class="pdp">
  <!-- GALLERY -->
  <div class="pdp-gallery" data-gallery>
    {%- if product.images.size > 0 -%}
      <div class="pdp-carousel" aria-label="Product images">
        {%- for image in product.images -%}
          <div class="pdp-carousel-slide">
            <img src="{{ image | image_url: width: 1200 }}"
                 alt="{{ image.alt | escape | default: product.title }}" width="1200" height="1600"
                 {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
    <div class="pdp-stage">
      {%- if product.featured_image -%}
        <img id="pdp-main-image" src="{{ product.featured_image | image_url: width: 1200 }}"
             alt="{{ product.featured_image.alt | escape | default: product.title }}" width="1200" height="1600">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
    {%- if product.images.size > 1 -%}
      <div class="pdp-thumbs" role="list">
        {%- for image in product.images -%}
          <button type="button" class="pdp-thumb{% if forloop.first %} sel{% endif %}"
                  data-full="{{ image | image_url: width: 1200 }}" aria-label="View image {{ forloop.index }}">
            <img src="{{ image | image_url: width: 200 }}" alt="" width="200" height="266" loading="lazy">
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- INFO -->
  <div class="pdp-info">
    <p class="pdp-eyebrow">{{ cat_label }}</p>
    <h1>{{ product.title }}</h1>

    <div class="pdp-rating">
      <span class="stars" aria-hidden="true">{% render 'icon', name: 'star', size: 14 %}{% render 'icon', name: 'star', size: 14 %}{% render 'icon', name: 'star', size: 14 %}{% render 'icon', name: 'star', size: 14 %}{% render 'icon', name: 'star', size: 14 %}</span>
      <span class="rating-text">4.8 &middot; 200+ reviews</span>
    </div>

    <p class="pdp-price">{{ product.price | money }}{% if product.compare_at_price > product.price %} <s>{{ product.compare_at_price | money }}</s>{% endif %}</p>

    {%- form 'product', product, id: 'product-form', class: 'pdp-form' -%}
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="opt">
            <div class="label">{{ option.name }}: <span class="opt-current" data-current>{{ option.selected_value }}</span></div>
            <div class="opt-buttons" data-option-index="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                <button type="button" class="opt-btn{% if option.selected_value == value %} sel{% endif %}"
                        data-value="{{ value | escape }}">{{ value }}</button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      <div class="opt">
        <div class="label">Quantity</div>
        <div class="qty">
          <button type="button" class="qty-btn" data-qty="-1" aria-label="Decrease">&minus;</button>
          <input type="number" name="quantity" id="qty-input" value="1" min="1" inputmode="numeric">
          <button type="button" class="qty-btn" data-qty="1" aria-label="Increase">+</button>
        </div>
      </div>

      <select name="id" id="variant-select" class="visually-hidden" aria-hidden="true">
        {%- for variant in product.variants -%}
          <option value="{{ variant.id }}"
                  {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                  {% unless variant.available %}disabled{% endunless %}>{{ variant.title }}</option>
        {%- endfor -%}
      </select>

      <button type="submit" name="add" class="addbtn"{% unless product.available %} disabled{% endunless %}>
        {%- if product.available -%}Add To Cart{%- else -%}Sold Out{%- endif -%}
      </button>
      {%- if product.available -%}{{ form | payment_button }}{%- endif -%}
    {%- endform -%}

    <div class="pdp-shortdesc">
      <p>The <strong>{{ product.title }}</strong> &mdash; {{ cat_line }}.</p>
      <ul>
        {%- for f in cat_features -%}<li>{{ f }}</li>{%- endfor -%}
      </ul>
      <p class="pdp-spec"><strong>Fabric:</strong> {{ cat_material }}</p>
      <p class="pdp-spec"><strong>Fit:</strong> {{ cat_fit }}{% if size_opt != blank %} Sizes {{ size_opt.values | join: ', ' }}.{% endif %}</p>
      <p class="pdp-spec"><strong>Shipping:</strong> Free U.S. shipping over $75 &middot; 30-day returns.</p>
    </div>
  </div>
</div>

<!-- YOU MAY ALSO LIKE (carousel of 6) -->
{%- assign rel = collections.all -%}
{%- for c in product.collections -%}
  {%- if c.handle != 'all' and c.handle != 'frontpage' and c.products_count > 1 -%}
    {%- assign rel = c -%}{%- break -%}
  {%- endif -%}
{%- endfor -%}
{%- assign rec_count = 0 -%}
<section class="pdp-rec-wrap">
  <h2 class="stl-title">YOU MAY ALSO LIKE</h2>
  <div class="rec-carousel">
    {%- for p in rel.products -%}
      {%- if p.id != product.id and rec_count < 6 -%}
        <a class="rec-card" href="{{ p.url }}">
          <div class="imgwrap">
            <img src="{{ p.featured_image | image_url: width: 500 }}" width="500" height="666" alt="{{ p.title | escape }}" loading="lazy">
          </div>
          <div class="t">{{ p.title }}</div>
          <div class="p">{{ p.price | money }}</div>
        </a>
        {%- assign rec_count = rec_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script>
(function(){
  // gallery
  var stage=document.getElementById('pdp-main-image');
  document.querySelectorAll('.pdp-thumb').forEach(function(t){
    t.addEventListener('click',function(){
      document.querySelectorAll('.pdp-thumb').forEach(function(x){x.classList.remove('sel')});
      t.classList.add('sel');
      if(stage) stage.src=t.getAttribute('data-full');
    });
  });
  // quantity
  var qi=document.getElementById('qty-input');
  document.querySelectorAll('.qty-btn').forEach(function(b){
    b.addEventListener('click',function(){
      var v=parseInt(qi.value||'1',10)+parseInt(b.getAttribute('data-qty'),10);
      qi.value=Math.max(1,v);
    });
  });
  // variant options
  var form=document.getElementById('product-form'); if(!form) return;
  var sel=document.getElementById('variant-select');
  var groups=form.querySelectorAll('.opt-buttons');
  function update(){
    var chosen=[];
    groups.forEach(function(g){
      var b=g.querySelector('.opt-btn.sel');
      var val=b?b.getAttribute('data-value'):'';
      chosen.push(val);
      var cur=g.parentElement.querySelector('[data-current]'); if(cur) cur.textContent=val;
    });
    var want=chosen.join(' / ');
    for(var i=0;i<sel.options.length;i++){
      if(sel.options[i].text===want || (groups.length===1 && sel.options[i].text===chosen[0])){ sel.selectedIndex=i; break; }
    }
  }
  groups.forEach(function(g){
    g.addEventListener('click',function(e){
      var b=e.target.closest('.opt-btn'); if(!b) return;
      g.querySelectorAll('.opt-btn').forEach(function(x){x.classList.remove('sel')});
      b.classList.add('sel'); update();
    });
  });
})();
</script>

{% schema %}
{ "name": "Product", "settings": [] }
{% endschema %}
